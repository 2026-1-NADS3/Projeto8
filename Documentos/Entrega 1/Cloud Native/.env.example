# =============================================================================
# .env — Variáveis de ambiente para docker-compose e scripts Shell
# NUNCA commite este arquivo com valores reais em repositórios públicos!
# Use .env.example com valores fictícios para documentar as variáveis.
# =============================================================================

# ── Aplicação ─────────────────────────────────────────────────────────────
APP_VERSION=1.0.0
SPRING_PROFILE=development       # development | staging | production

# ── API ───────────────────────────────────────────────────────────────────
API_PORT=8080
JAVA_OPTS=-Xms256m -Xmx1g -XX:+UseG1GC

# ── Banco de Dados ────────────────────────────────────────────────────────
DB_TYPE=postgres
DB_HOST=localhost
DB_PORT=5432
DB_NAME=appdb
DB_USER=appuser
DB_PASS=changeme_secret

# Expõe porta do Postgres ao host (apenas em dev)
POSTGRES_EXPOSE_PORT=5432

# ── Redis ─────────────────────────────────────────────────────────────────
REDIS_EXPOSE_PORT=6379

# ── Nginx ─────────────────────────────────────────────────────────────────
HTTP_PORT=80
HTTPS_PORT=443

# ── Adminer (dev only) ────────────────────────────────────────────────────
ADMINER_PORT=8888

# ── Backup ────────────────────────────────────────────────────────────────
BACKUP_DIR=/var/backups/devapp
SOURCE_DIR=/opt/app/src
BACKUP_RETENTION_DAYS=7
COMPRESS=true
ENCRYPT=false
# GPG_KEY_ID=sua@chave.gpg
# NOTIFY_WEBHOOK=https://hooks.slack.com/services/xxx/yyy/zzz

# ── Monitoramento ─────────────────────────────────────────────────────────
MONITOR_LOG_DIR=/var/log/app-monitor
ALERT_CPU_THRESHOLD=85
ALERT_MEM_THRESHOLD=90
ALERT_DISK_THRESHOLD=80

# ── Gerenciamento de serviços ─────────────────────────────────────────────
APP_DIR=/opt/app
LOG_DIR=/var/log/backend
PID_DIR=/var/run/backend
JAVA_HOME=/usr/lib/jvm/java-17-openjdk-amd64
WORKER_ENABLED=true
USE_DOCKER=false
WATCHDOG_INTERVAL=30
WATCHDOG_MAX_RESTARTS=5
